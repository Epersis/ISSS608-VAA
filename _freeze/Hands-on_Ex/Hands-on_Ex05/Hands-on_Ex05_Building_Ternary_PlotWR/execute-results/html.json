ver\",\"plotly_click\",\"plotly_selected\",\"plotly_relayout\",\"plotly_brushed\",\"plotly_brushing\",\"plotly_clickannotation\",\"plotly_doubleclick\",\"plotly_deselect\",\"plotly_afterplot\",\"plotly_sunburstclick\"],\"base_url\":\"https://plot.ly\"},\"evals\":[],\"jsHooks\":[]}</script>\n```\n\n:::\n:::\n\n## The code\n\n::: {.cell}\n\n```{.r .cell-code}\n# reusable function for creating annotation object\nlabel <- function(txt) {\n  list(\n    text = txt, \n    x = 0.1, y = 1,\n    ax = 0, ay = 0,\n    xref = \"paper\", yref = \"paper\", \n    align = \"center\",\n    font = list(family = \"serif\", size = 15, color = \"white\"),\n    bgcolor = \"#b3b3b3\", bordercolor = \"black\", borderwidth = 2\n  )\n}\n\n# reusable function for axis formatting\naxis <- function(txt) {\n  list(\n    title = txt, tickformat = \".0%\", tickfont = list(size = 10)\n  )\n}\n\nternaryAxes <- list(\n  aaxis = axis(\"Young\"), \n  baxis = axis(\"Active\"), \n  caxis = axis(\"Old\")\n)\n\n# Initiating a plotly visualization \nplot_ly(\n  agpop_mutated, \n  a = ~YOUNG, \n  b = ~ACTIVE, \n  c = ~OLD, \n  color = I(\"black\"), \n  type = \"scatterternary\"\n) %>%\n  layout(\n    annotations = label(\"Ternary Markers\"), \n    ternary = ternaryAxes\n  )\n```\n:::\n\n:::\n\n# Alternatives\n\n## Ternary plot with colour by planning area\n\n::: panel-tabset\n## The plot\n\n\n::: {.cell}\n::: {.cell-output-display}\n![](Hands-on_Ex05_Building_Ternary_PlotWR_files/figure-html/unnamed-chunk-10-1.png){width=960}\n:::\n:::\n\n## The code\n\n::: {.cell}\n\n```{.r .cell-code}\nlibrary(ggtern)\n\nggtern(\n  data = agpop_mutated,\n  aes(\n    x = YOUNG,\n    y = ACTIVE,\n    z = OLD,\n    color = PA\n  )\n) +\n\n  geom_point(size = 2, alpha = 0.8) +\n\n  labs(\n    title = \"Population Structure by Planning Area (2018)\",\n    x = \"Young\",\n    y = \"Economically Active\",\n    z = \"Old\"\n  ) +\n\n  theme_bw() +\n\n  theme(\n    plot.title = element_text(\n      hjust = 0.5,\n      size = 16,\n      face = \"bold\"\n    ),\n\n    legend.position = \"bottom\",\n\n    legend.title = element_text(size = 10),\n    legend.text = element_text(size = 7),\n\n    tern.axis.title.T = element_text(size = 12),\n    tern.axis.title.L = element_text(size = 12),\n    tern.axis.title.R = element_text(size = 12),\n\n    tern.axis.text.T = element_text(size = 8),\n    tern.axis.text.L = element_text(size = 8),\n    tern.axis.text.R = element_text(size = 8),\n\n    plot.margin = margin(\n      t = 20,\n      r = 40,\n      b = 20,\n      l = 40\n    )\n  )\n```\n:::\n\n:::\n\n## Bubble Ternary Plot, point size by total population\n\n::: panel-tabset\n## The plot\n\n\n::: {.cell}\n::: {.cell-output-display}\n![](Hands-on_Ex05_Building_Ternary_PlotWR_files/figure-html/unnamed-chunk-12-1.png){width=672}\n:::\n:::\n\n## The code\n\n::: {.cell}\n\n```{.r .cell-code}\nggtern(data = agpop_mutated,\n       aes(x = YOUNG,\n           y = ACTIVE,\n           z = OLD,\n           size = TOTAL)) +\n  \n  geom_point(alpha = 0.7, color = \"steelblue\") +\n  \n  labs(\n    title = \"Population Composition with Population Size\",\n    size = \"Total Population\"\n  ) +\n  \n  theme_bw()\n```\n:::\n\n:::\n\n## Interactive Plotly Ternary Plot with Hover Labels\n\n::: panel-tabset\n## The plot\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<div class=\"plotly html-widget html-fill-item\" id=\"htmlwidget-e6d8c275083e1f3c60bd\" style=\"width:100%;height:464px;\"></div>\n<script type=\"application/json\" data-for=\"htmlwidget-e6d8c275083e1f3c60bd\">{\"x\":{\"visdat\":{\"cac4cd05262\":[\"function () \",\"plotlyVisDat\"]},\"cur_data\":\"cac4cd05262\",\"attrs\":{\"cac4cd05262\":{\"a\":{},\"b\":{},\"c\":{},\"mode\":\"markers\",\"text\":{},\"hoverinfo\":\"text\",\"marker\":{\"size\":8,\"color\":\"darkred\"},\"alpha_stroke\":1,\"sizes\":[10,100],\"spans\":[1,20],\"type\":\"scatterternary\"}},\"layout\":{\"margin\":{\"b\":50,\"l\":50,\"t\":100,\"r\":50},\"title\":\"Interactive Population Ter